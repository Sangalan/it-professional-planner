# Task completion documents — load only when explicitly requested
.claude/completions/**

# Session files — load only when explicitly requested
.claude/sessions/**

# Archived documentation — load only when explicitly requested
docs/archive/**

# Dependencies
node_modules/**
backend/node_modules/**
frontend/node_modules/**

# Build output
frontend/dist/**
frontend/.vite/**

# Git
.git/**

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/**

# Database binary files (read via SQL, not as text)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Uploaded files
backend/data/uploads/**

# IDE / OS
.vscode/**
.idea/**
.DS_Store
